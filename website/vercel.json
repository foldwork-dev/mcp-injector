{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/install", "destination": "/install.sh", "permanent": true }
  ],
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [{"key": "Content-Type", "value": "application/xml"}]
    },
    {
      "source": "/robots.txt", 
      "headers": [{"key": "Content-Type", "value": "text/plain"}]
    }
  ]
}
