#!/bin/bash
#
# Pre-commit hook to run consistency checks on impact areas.
#

# Ensure we're at the root of the repo
cd "$(git rev-parse --show-toplevel)" || exit 1

echo "Running pre-commit consistency checks..."
if ! python3 scripts/lint-consistency.py; then
    echo "ERROR: Consistency lint failed. Please fix the above errors before committing."
    echo "This ensures impact areas are correctly updated!"
    exit 1
fi

echo "Running SEO checks..."
if ! python3 scripts/lint-seo.py; then
    echo "ERROR: SEO lint failed. Please fix the above SEO errors."
    exit 1
fi

echo "Generating sitemap..."
if ! python3 scripts/generate-sitemap.py; then
    echo "ERROR: Sitemap generation failed."
    exit 1
fi
git add website/sitemap.xml

echo "All checks passed!"
exit 0
